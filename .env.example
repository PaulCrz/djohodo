# Djohodo — environment template
# Copy to `.env` and fill in. Never commit your real `.env`.

# --- Model selection ---------------------------------------------------------
# Default model id used by watcher.agent. Haiku 4.5 is the cheapest current model.
# Switch to "claude-sonnet-4-6" later when richer analysis is needed.
DJOHODO_MODEL=claude-haiku-4-5-20251001

# --- Portfolio source --------------------------------------------------------
# Optional. If set, the watcher fetches a Google Sheet exported as CSV at this
# URL (no API key needed; the sheet just has to be "anyone with link" or
# "publish to web" with CSV output). If unset, it falls back to ./portfolio.json.
# Expected columns: ticker, name (header row optional).
# PORTFOLIO_SHEET_URL=https://docs.google.com/spreadsheets/d/.../export?format=csv

# --- Authentication ----------------------------------------------------------
# Pick ONE of the two paths:
#
# (a) Subscription credit (recommended for local use):
#     - Make sure ANTHROPIC_API_KEY is UNSET (comment it out below).
#     - Run `claude login` once so the Agent SDK uses your subscription credit.
#
# (b) Pay-as-you-go:
#     - Set ANTHROPIC_API_KEY below.
#
# ANTHROPIC_API_KEY=sk-ant-...

# --- Delivery (SMTP, optional) ----------------------------------------------
# Set to 1 to also email the digest. All SMTP_* vars are then required.
DJOHODO_EMAIL_ENABLED=0
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=change-me
SMTP_FROM=you@example.com
SMTP_TO=you@example.com

# --- Delivery (Telegram, optional) ------------------------------------------
# Set to 1 to also push the digest to a Telegram chat.
DJOHODO_TELEGRAM_ENABLED=0
# Issued by @BotFather when you create the bot (format: 123456:ABC-...).
TELEGRAM_BOT_TOKEN=
# Where to send the digest:
#   - your numeric user id (private chat) — ask @userinfobot for it
#   - or -100... for a channel/supergroup
#   - or @channel_username for a public channel
TELEGRAM_CHAT_ID=

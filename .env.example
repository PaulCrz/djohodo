# Model selection
DJOHODO_MODEL=

# Portfolio source
PORTFOLIO_SHEET_URL=

# Set to 1 to push the digest to a Telegram chat (sole delivery channel)
DJOHODO_TELEGRAM_ENABLED=

# Issued by @BotFather when you create the bot (format: 123456:ABC-...)
TELEGRAM_BOT_TOKEN=

# Where to send the digest: numeric user id (private chat) or channel/supergroup
TELEGRAM_CHAT_ID=

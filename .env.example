# Djohodo — environment template
# Copy to `.env` and fill in. Never commit your real `.env`.

# --- Model selection ---------------------------------------------------------
# Default model id used by watcher.agent. Haiku 4.5 is the cheapest current model.
# Switch to "claude-sonnet-4-6" later when richer analysis is needed.
DJOHODO_MODEL=claude-haiku-4-5-20251001

# --- Portfolio source --------------------------------------------------------
# Required. Google Sheet exported as CSV (File → Share → Publish to web → CSV,
# or share "anyone with link" and use the /export?format=csv URL). The watcher
# extracts tradable holdings from this on every run via a cheap LLM pre-pass.
PORTFOLIO_SHEET_URL=

# --- Authentication ----------------------------------------------------------
# Pick ONE of the two paths:
#
# (a) Subscription credit (recommended for local use):
#     - Make sure ANTHROPIC_API_KEY is UNSET (comment it out below).
#     - Run `claude login` once so the Agent SDK uses your subscription credit.
#
# (b) Pay-as-you-go:
#     - Set ANTHROPIC_API_KEY below.
#
# ANTHROPIC_API_KEY=sk-ant-...

# --- Delivery (Telegram) ----------------------------------------------------
# Set to 1 to push the digest to a Telegram chat (sole delivery channel).
DJOHODO_TELEGRAM_ENABLED=0
# Issued by @BotFather when you create the bot (format: 123456:ABC-...).
TELEGRAM_BOT_TOKEN=
# Where to send the digest:
#   - your numeric user id (private chat) — ask @userinfobot for it
#   - or -100... for a channel/supergroup
#   - or @channel_username for a public channel
TELEGRAM_CHAT_ID=
